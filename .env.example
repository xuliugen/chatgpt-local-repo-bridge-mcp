# MCP Server 端口
PORT=3100

# 允许访问的工作区目录 (逗号分隔，支持多个目录)
WORKSPACES=D:\CodeX\chatgpt-local-repo-bridge-mcp,D:\CodeX\mindx-agent

# 工具注册模式：full 注册全部工具；minimal/codex 隐藏完整 Git 工具以减少 ChatGPT UI 噪声。
TOOL_MODE=full

# 强制禁止直接访问的目录名 (逗号分隔，匹配任意层级)。仅用于安全边界。
# 不配置则使用默认值: .git
ACCESS_BLOCKED_DIRS=

# 历史兼容配置：作为遍历/搜索忽略目录处理，不阻止显式路径访问。
EXCLUDED_DIRS=.git

# 遍历和搜索时默认忽略的高噪声目录名，不阻止显式路径访问。
# 不配置则使用内置默认高噪声目录列表。
TRAVERSAL_IGNORED_DIRS=

# 排除的敏感文件名 / glob 模式 (逗号分隔，仅匹配 basename)
# 不配置则使用默认值: .env,.env.local,.env.development,.env.development.local,.env.production,.env.production.local,.env.test,.env.test.local,.env.staging,.env.staging.local,.envrc,.npmrc,.pypirc,*.pem,*.key,*.crt,*.cer,*.p12,*.pfx,id_rsa,id_rsa.*,id_ed25519,id_ed25519.*
EXCLUDED_FILES=.env,.env.local,.env.development,.env.development.local,.env.production,.env.production.local,.env.test,.env.test.local,.env.staging,.env.staging.local,.envrc,.npmrc,.pypirc,*.pem,*.key,*.crt,*.cer,*.p12,*.pfx,id_rsa,id_rsa.*,id_ed25519,id_ed25519.*

# 允许的跨域来源 (逗号分隔)。CORS 不是鉴权；公网暴露时请注意安全。
ALLOWED_ORIGINS=https://chatgpt.com,https://chat.openai.com

# OAuth / Auth0 认证配置。公网暴露时建议启用。
OAUTH_ENABLED=true
PUBLIC_MCP_URL=https://conxxxxxxxx.ngrok-free.dev/mcp
OAUTH_ISSUER=https://dev-xxxxxxxx.us.auth0.com/
OAUTH_AUDIENCE=https://conxxxxxxxx.ngrok-free.dev/mcp
OAUTH_SCOPES=repo:read,repo:write,repo:git

# 是否在根路径 / 和 /health 暴露详细工具清单、会话数等信息。公网建议 false。
EXPOSE_PUBLIC_INFO=false

# 是否注册终端工具，包括 exec_command、write_stdin、run_command_start/read/cancel。公网建议保持 false。
ENABLE_TERMINAL=false

# 启用终端工具后，默认只允许这些完整命令。逗号分隔。
# 示例: npm run build,npm test,git status
ALLOWED_COMMANDS=npm run build,npm test,git status,npm run archive:mindx,npm run cover:mindx

# 是否允许终端工具执行任意命令。公网严禁 true。
ALLOW_ANY_COMMAND=false

# 命令日志模式：summary 只写命令摘要和状态；full 逐 chunk 写完整输出；off 不写日志。默认推荐 summary。
COMMAND_LOG_MODE=summary

# 是否允许 git push --force。
ALLOW_GIT_FORCE_PUSH=false

# 文件读写限制
MAX_READ_BYTES=1048576
MAX_WRITE_BYTES=2097152

# MCP 会话与限流
MAX_SESSIONS=100
SESSION_TTL_MS=600000
SESSION_LIMIT_RECLAIM_IDLE_MS=120000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
