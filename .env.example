# MCP Server 端口
PORT=3100

# 允许访问的工作区目录 (逗号分隔，支持多个目录)
WORKSPACES=D:\CodeX\chatgpt-local-repo-bridge-mcp,D:\CodeX\mindx-agent

# 排除的目录名 (逗号分隔，匹配任意层级)
# 不配置则使用默认值: node_modules,.git,dist,build,.next,.nuxt,__pycache__,.venv,.tox,venv,.cache,coverage,.qoder
EXCLUDED_DIRS=node_modules,.git,dist,build,.next,__pycache__,.venv,.cache,coverage,DS_Store,.qoder

# 排除的敏感文件名 / glob 模式 (逗号分隔，仅匹配 basename)
# 不配置则使用默认值: .env,.env.local,.env.development,.env.development.local,.env.production,.env.production.local,.env.test,.env.test.local,.env.staging,.env.staging.local,.envrc,.npmrc,.pypirc,*.pem,*.key,*.crt,*.cer,*.p12,*.pfx,id_rsa,id_rsa.*,id_ed25519,id_ed25519.*
EXCLUDED_FILES=.env,.env.local,.env.development,.env.development.local,.env.production,.env.production.local,.env.test,.env.test.local,.env.staging,.env.staging.local,.envrc,.npmrc,.pypirc,*.pem,*.key,*.crt,*.cer,*.p12,*.pfx,id_rsa,id_rsa.*,id_ed25519,id_ed25519.*

# 允许的跨域来源 (逗号分隔)。CORS 不是鉴权；公网暴露时请配置 MCP_AUTH_TOKEN 或 OAuth 代理。
ALLOWED_ORIGINS=https://chatgpt.com,https://chat.openai.com

# 可选 Bearer token。配置后 /mcp 请求必须携带: Authorization: Bearer <token>
# 注意: 如果 ChatGPT 自定义连接器未配置对应认证，请先留空，否则无法连接。
MCP_AUTH_TOKEN=

# 是否在根路径 / 和 /health 暴露详细工具清单、会话数等信息。公网建议 false。
EXPOSE_PUBLIC_INFO=false

# 是否注册 run_command 工具。公网建议保持 false。
ENABLE_TERMINAL=false

# 启用 run_command 后，默认只允许这些完整命令。逗号分隔。
# 示例: npm run build,npm test,git status
ALLOWED_COMMANDS=npm run build,npm test,git status

# 旧配置名仍兼容，但语义已从“前缀”改为“完整命令”。建议改用 ALLOWED_COMMANDS。
# ALLOWED_COMMAND_PREFIXES=

# 是否允许 run_command 执行任意命令。公网严禁 true。
ALLOW_ANY_COMMAND=false

# 是否允许 git push --force。
ALLOW_GIT_FORCE_PUSH=false

# 文件读写限制
MAX_READ_BYTES=1048576
MAX_WRITE_BYTES=2097152

# MCP 会话与限流
MAX_SESSIONS=25
SESSION_TTL_MS=1800000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
